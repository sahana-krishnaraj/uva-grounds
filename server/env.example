# Copy to .env and fill in. Required for sign-up / login APIs:
SUPABASE_SERVICE_ROLE_KEY=

# Optional overrides (defaults match js/supabase.js for local dev):
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Outbound email (if unset, verification codes are printed to the server console):
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=HoosOut <noreply@yourdomain.edu>

# PORT=3000
